# ARIA Local Voice Assistant — Environment Config
# Copy this file to .env and adjust as needed.

# ── Whisper (Speech-to-Text) ──────────────────────────────────
# Options: tiny | base | small | medium | large
# tiny   = fastest,  lowest accuracy (~39M params)
# base   = good balance                (~74M params)
# small  = better accuracy            (~244M params)
# medium = high accuracy              (~769M params)
# large  = best accuracy, slowest    (~1550M params)
WHISPER_MODEL=small

# ── Ollama (LLM) ──────────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434

# Any model pulled via: ollama pull <model>
# Recommended: mistral | llama3 | phi3 | gemma | openchat
OLLAMA_MODEL=mistral

# ── Coqui TTS (Text-to-Speech) ────────────────────────────────
# Language code for TTS
TTS_LANGUAGE=en

# ── Server ────────────────────────────────────────────────────
PORT=5000
